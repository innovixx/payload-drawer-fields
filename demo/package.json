{
  "name": "website-payload-boilerplate",
  "version": "0.0.0",
  "description": "A boilerplate for a Payload server",
  "repository": "git@github.com:innovixx/website-payload-boilerplate.git",
  "author": "Innovixx <support@innovixx.co.uk>",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 9000",
    "cleanDev": "rm -rf ./storage && cross-env PAYLOAD_DROP_DATABASE=true PAYLOAD_SEED_DATABASE=true next dev -p 9000",
    "build": "next build",
    "serve": "cross-env NODE_ENV=production next start -p 9000",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "generate:graphql": "payload generate:graphQLSchema",
    "lint": "eslint ./src --ext .js,.jsx,.ts,.tsx",
    "lint-staged": "lint-staged --verbose",
    "prepare": "husky"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@payloadcms/db-mongodb": "3.83.0",
    "@payloadcms/next": "3.83.0",
    "@payloadcms/richtext-lexical": "3.83.0",
    "body-parser": "^2.2.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "next": "16.2.4",
    "payload": "3.83.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@innovixx/eslint-config": "^3.0.12",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "copyfiles": "^2.4.1",
    "eslint": "^10.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-sort-export-all": "^2.1.0",
    "eslint-plugin-sort-keys-fix": "^1.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "**/*.{js,ts,jsx,tsx}": [
      "eslint",
      "bash -c tsc"
    ]
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  }
}